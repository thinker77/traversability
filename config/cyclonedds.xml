<!--
  CycloneDDS configuration for traversability_generator.

  Shared memory (Iceoryx) is DISABLED by default so the container works
  without a RouDi daemon. To enable zero-copy on bare-metal or with
  --ipc=host, set <Enable>true</Enable> and start RouDi first:
      iox-roudi &

  Set via: export CYCLONEDDS_URI=file://$(pwd)/config/cyclonedds.xml
-->
<CycloneDDS>
  <Domain>
    <General>
      <Interfaces>
        <NetworkInterface autodetermine="true" priority="default" multicast="default"/>
      </Interfaces>
    </General>

    <!-- Shared memory: zero-copy for PointCloud2 / Image topics on localhost -->
    <SharedMemory>
      <Enable>false</Enable>
      <LogLevel>info</LogLevel>
    </SharedMemory>

    <!-- Larger receive buffers for PointCloud2.
         On bare-metal set net.core.rmem_max=10485760 and uncomment:
    <Internal>
      <SocketReceiveBufferSize min="10MB"/>
    </Internal>
    -->
  </Domain>
</CycloneDDS>
