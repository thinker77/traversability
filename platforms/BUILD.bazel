package(default_visibility = ["//visibility:public"])

# ── x86_64 + CUDA GPU (T4 development machine) ───────────────────────────────
platform(
    name = "x86_64_gpu",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
)

# ── NVIDIA Thor (aarch64, Drive OS / Blackwell GPU) ──────────────────────────
platform(
    name = "thor_aarch64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:aarch64",
    ],
)
